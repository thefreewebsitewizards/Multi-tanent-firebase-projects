rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin(storeId) {
      return request.auth != null
        && request.auth.token.storeId == storeId
        && request.auth.token.role == 'admin';
    }

    function hasActiveMembership(storeId) {
      let membership = get(/databases/$(database)/documents/stores/$(storeId)/memberships/$(request.auth.uid));
      return membership.exists()
        && (membership.data.accessType == 'lifetime'
          || (membership.data.accessEnd != null && membership.data.accessEnd > request.time));
    }

    function canReadStore(storeId) {
      return request.auth != null
        && request.auth.token.storeId == storeId
        && (isAdmin(storeId) || hasActiveMembership(storeId));
    }

    match /stores/{storeId}/memberships/{memberId} {
      allow read: if request.auth != null
        && request.auth.uid == memberId
        && request.auth.token.storeId == storeId;
      allow write: if isAdmin(storeId);
    }

    // Public blog posts — anyone can read published posts
    match /stores/{storeId}/posts/{postId} {
      allow read: if true;
      allow write: if isAdmin(storeId);
    }

    // Comments — anyone can read, anyone can create (with basic fields)
    match /stores/{storeId}/comments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin(storeId);
    }

    // Public products for all stores
    match /stores/{storeId}/products/{productId} {
      allow read: if true;
      allow write: if isAdmin(storeId);
    }

    // Catch-all for other subcollections (staff, etc.)
    match /stores/{storeId}/{document=**} {
      allow read: if canReadStore(storeId);
      allow write: if isAdmin(storeId);
    }
  }
}
